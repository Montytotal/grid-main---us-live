# Database connection settings.
#
# Use "database" for Docker. Use "localhost" or a private database host in
# production.
DATABASE_HOSTNAME=localhost
DATABASE_USERNAME=grid
DATABASE_PASSWORD=
DATABASE_DATABASE=grid

# Number of repeated update failures before PHP reports an error.
# Use 0 while setting up, then 1 or higher in production.
ERROR_REPORTING_THRESHOLD=1

# Optional Cloudflare analytics settings.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Required for the US page and EIA-930 fallback data.
EIA_API_KEY=

# Optional Google AdSense settings for the US page.
GOOGLE_ADSENSE_CLIENT=
GOOGLE_ADSENSE_SLOT_TOP=
GOOGLE_ADSENSE_SLOT_MID=
